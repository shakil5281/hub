<header class="erp-navbar">
    <div class="flex min-w-0 items-center gap-3">
        <button type="button" class="erp-btn-icon lg:hidden" @@click="sidebarOpen = !sidebarOpen" aria-label="Toggle menu">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
        <nav class="flex min-w-0 items-center gap-2 text-sm" aria-label="Breadcrumb">
            <a href="@Url.Action("Index", "Home")" class="hidden shrink-0 text-muted transition hover:text-foreground sm:inline">ERP Hub</a>
            <svg class="hidden h-3.5 w-3.5 shrink-0 text-muted sm:inline" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
            <span class="truncate font-medium text-foreground">@ViewData["Title"]</span>
        </nav>
    </div>

    <div class="flex flex-1 justify-center px-2 sm:px-4">
        <div class="w-full max-w-md">
            @await Html.PartialAsync("Partials/_NavbarSearch")
        </div>
    </div>

    <div class="flex items-center gap-1 sm:gap-2">
        @await Html.PartialAsync("Partials/_NavbarNotifications")
        @await Html.PartialAsync("Partials/_UserProfileDropdown")
    </div>
</header>
