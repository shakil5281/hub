@model ERP.Web.Models.SidebarVm
<aside class="erp-sidebar"
       :class="sidebarOpen ? 'translate-x-0' : '-translate-x-full lg:translate-x-0'">
    <div class="erp-sidebar-brand">
        <a href="@Model.DashboardHref" @@click="sidebarOpen = false" class="flex min-w-0 flex-1 items-center gap-3">
            <div class="erp-sidebar-logo">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                    <polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
            </div>
            <div class="min-w-0">
                <div class="truncate text-sm font-semibold text-gray-800">ERP Hub</div>
                <div class="truncate text-xs text-gray-500">Enterprise HR Suite</div>
            </div>
        </a>
    </div>

    <nav class="erp-sidebar-nav pt-2">
        @await Html.PartialAsync("Partials/_SidebarLink", ("Dashboard", Model.DashboardHref, "dashboard", Model.IsDashboardActive))

        @foreach (var group in Model.Groups)
        {
            @await Html.PartialAsync("Partials/_SidebarGroup", group)
        }
    </nav>
</aside>
<div class="fixed inset-0 z-30 bg-black/50 backdrop-blur-sm lg:hidden" x-show="sidebarOpen" @@click="sidebarOpen = false" x-cloak></div>
