@using ERP.Web.Core.DTOs
@model AttendanceFilterDto
@{
    var departments = (IReadOnlyList<ERP.Web.Areas.Company.ViewModels.DepartmentVm>)(ViewBag.Departments ?? Array.Empty<ERP.Web.Areas.Company.ViewModels.DepartmentVm>());
    var sections = (IReadOnlyList<ERP.Web.Areas.Company.ViewModels.SectionVm>)(ViewBag.Sections ?? Array.Empty<ERP.Web.Areas.Company.ViewModels.SectionVm>());
    var action = ViewBag.FilterAction as string ?? Url.Action(ViewContext.RouteData.Values["action"]!.ToString()!)!;
    var module = ViewBag.FilterModule as string ?? "Attendance";
}

<div class="erp-filter-panel mb-6" x-data="{ tab: 'filters', showSave: false, presetName: '' }">
    <div class="erp-filter-tabs">
        <button type="button" @@click="tab = 'filters'" :class="tab === 'filters' ? 'erp-filter-tab erp-filter-tab-active' : 'erp-filter-tab'">Filters</button>
        <button type="button" @@click="tab = 'presets'" :class="tab === 'presets' ? 'erp-filter-tab erp-filter-tab-active' : 'erp-filter-tab'">Saved Presets</button>
    </div>
    <div class="erp-filter-header">
        <div>
            <p class="text-sm font-semibold">Attendance Database Filters</p>
            <p class="text-xs text-muted">Filter by date range, org structure, and status</p>
        </div>
        <div class="flex gap-2">
            <button type="button" @@click="showSave = !showSave" class="erp-btn-secondary text-xs">Save Preset</button>
            <a href="@action" class="erp-btn-ghost text-xs">Reset all</a>
        </div>
    </div>
    <div x-show="showSave" x-cloak class="border-b border-border bg-neutral-50 px-4 py-3">
        <div class="flex flex-wrap items-end gap-3">
            <div class="min-w-[200px] flex-1">
                <label class="erp-label-muted">Preset name</label>
                <input type="text" x-model="presetName" class="erp-input" placeholder="This month absences" />
            </div>
            <button type="button" class="erp-btn-primary" @@click="erpSaveFilterPreset('@module', presetName, document.getElementById('filterForm'))">Save</button>
        </div>
    </div>
    <div class="erp-filter-body" x-show="tab === 'filters'">
        <form id="filterForm" method="get" action="@action" class="erp-filter-grid">
            <div>
                <label class="erp-label-muted">From date</label>
                <input type="date" name="From" value="@Model.From?.ToString("yyyy-MM-dd")" class="erp-input" data-datepicker placeholder="From date" />
            </div>
            <div>
                <label class="erp-label-muted">To date</label>
                <input type="date" name="To" value="@Model.To?.ToString("yyyy-MM-dd")" class="erp-input" data-datepicker placeholder="To date" />
            </div>
            <div>
                <label class="erp-label-muted">Search</label>
                <input type="text" name="Search" value="@Model.Search" placeholder="Name or code…" class="erp-input" />
            </div>
            <div>
                <label class="erp-label-muted">Department</label>
                <select name="DepartmentId" class="erp-input">
                    <option value="">All departments</option>
                    @foreach (var d in departments) { <option value="@d.Id" selected="@(Model.DepartmentId == d.Id)">@d.Name</option> }
                </select>
            </div>
            <div>
                <label class="erp-label-muted">Section</label>
                <select name="SectionId" class="erp-input">
                    <option value="">All sections</option>
                    @foreach (var s in sections) { <option value="@s.Id" selected="@(Model.SectionId == s.Id)">@s.Name</option> }
                </select>
            </div>
            <div>
                <label class="erp-label-muted">Absent</label>
                <select name="IsAbsent" class="erp-input">
                    <option value="">All</option>
                    <option value="true" selected="@(Model.IsAbsent == true)">Yes</option>
                    <option value="false" selected="@(Model.IsAbsent == false)">No</option>
                </select>
            </div>
            <div>
                <label class="erp-label-muted">Approved</label>
                <select name="IsApproved" class="erp-input">
                    <option value="">All</option>
                    <option value="true" selected="@(Model.IsApproved == true)">Yes</option>
                    <option value="false" selected="@(Model.IsApproved == false)">No</option>
                </select>
            </div>
            <div class="flex items-end gap-2 sm:col-span-2 lg:col-span-4">
                <button type="submit" class="erp-btn-primary">Apply filters</button>
            </div>
        </form>
    </div>
    <div class="erp-filter-body" x-show="tab === 'presets'" x-cloak>
        <div id="preset-list-@module" class="text-sm text-muted">No saved presets yet.</div>
    </div>
</div>
