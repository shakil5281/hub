@model IReadOnlyList<(string Label, string? Href, string? DeleteFormId, bool IsDanger)>
<div class="erp-row-actions">
    @foreach (var action in Model)
    {
        var actionClass = action.IsDanger ? "erp-row-action erp-row-action-danger" : "erp-row-action";
        if (!string.IsNullOrEmpty(action.Href))
        {
            <a href="@action.Href" class="@actionClass">@action.Label</a>
        }
        else if (!string.IsNullOrEmpty(action.DeleteFormId))
        {
            <button type="button" class="@actionClass" @@click="$dispatch('confirm-delete', '@action.DeleteFormId')">@action.Label</button>
        }
    }
</div>
