<button type="button"
        @@click="$store.search.open()"
        class="erp-search-trigger hidden w-full sm:flex"
        title="Search (Ctrl+K)"
        aria-label="Search">
    <svg class="h-4 w-4 shrink-0 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
    </svg>
    <span class="text-sm text-gray-400">Search...</span>
    <kbd class="erp-search-kbd-inline ml-auto">Ctrl K</kbd>
</button>

<button type="button"
        @@click="$store.search.open()"
        class="erp-btn-icon sm:hidden"
        title="Search"
        aria-label="Search">
    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
</button>
