@using System.Security.Claims
@{
    var fullName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "User";
    var email = User.Identity?.Name ?? "";
    var role = User.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role)?.Value ?? "User";
    var nameParts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
    var initials = nameParts.Length >= 2
        ? $"{nameParts[0][0]}{nameParts[^1][0]}"
        : fullName.Length >= 2 ? fullName[..2] : fullName;
    initials = initials.ToUpperInvariant();
}
<div class="relative" x-data="{ open: false }" @@click.outside="open = false" @@keydown.escape.window="open = false">
    <button type="button"
            @@click="open = !open"
            class="erp-user-trigger"
            :aria-expanded="open"
            aria-haspopup="true">
        <span class="erp-user-avatar">@initials</span>
        <span class="hidden min-w-0 text-left md:block">
            <span class="block truncate text-sm font-medium text-foreground">@fullName</span>
            <span class="block truncate text-xs text-muted">@role</span>
        </span>
        <svg class="hidden h-4 w-4 shrink-0 text-muted transition md:block" :class="open ? 'rotate-180' : ''" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="m6 9 6 6 6-6"/>
        </svg>
    </button>

    <div x-show="open"
         x-transition:enter="transition ease-out duration-150"
         x-transition:enter-start="opacity-0 scale-95"
         x-transition:enter-end="opacity-100 scale-100"
         x-transition:leave="transition ease-in duration-100"
         x-transition:leave-start="opacity-100 scale-100"
         x-transition:leave-end="opacity-0 scale-95"
         x-cloak
         class="erp-user-menu">
        <div class="erp-user-menu-header">
            <span class="erp-user-avatar erp-user-avatar-lg">@initials</span>
            <div class="min-w-0">
                <p class="truncate text-sm font-semibold text-foreground">@fullName</p>
                <p class="truncate text-xs text-muted">@email</p>
            </div>
        </div>

        <div class="erp-user-menu-section">
            <a href="@Url.Action("Index", "Company", new { area = "Company" })" class="erp-user-menu-item" @@click="open = false">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><rect x="4" y="2" width="16" height="20" rx="2"/><path d="M9 22v-4h6v4"/></svg>
                Company Profile
            </a>
            <a href="@Url.Action("Index", "User", new { area = "Admin" })" class="erp-user-menu-item" @@click="open = false">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                My Account
            </a>
            <a href="@Url.Action("Index", "Role", new { area = "Admin" })" class="erp-user-menu-item" @@click="open = false">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                Roles &amp; Access
            </a>
            <a href="#" class="erp-user-menu-item" @@click="open = false">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
                Settings
            </a>
            <a href="#" class="erp-user-menu-item" @@click="open = false">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
                Help &amp; Support
            </a>
        </div>

        <div class="erp-user-menu-divider"></div>

        <form asp-controller="Account" asp-action="Logout" method="post" class="erp-user-menu-section">
            @Html.AntiForgeryToken()
            <button type="submit" class="erp-user-menu-item erp-user-menu-item-danger w-full">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                Sign out
            </button>
        </form>
    </div>
</div>
