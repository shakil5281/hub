<div x-data="erpNotifications()" x-init="load()" class="relative">
    <button type="button"
            @@click="toggle()"
            class="erp-btn-icon relative"
            title="Notifications"
            aria-label="Notifications">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        <span x-show="unreadCount > 0"
              x-text="unreadCount > 9 ? '9+' : unreadCount"
              class="erp-notification-badge"></span>
    </button>

    <div x-show="open"
         x-transition
         @@click.outside="open = false"
         x-cloak
         class="erp-notification-menu">
        <div class="erp-notification-header">
            <h3 class="text-sm font-semibold text-foreground">Notifications</h3>
            <button type="button" @@click="load()" class="text-xs font-medium text-primary hover:underline" :disabled="loading">
                <span x-show="!loading">Refresh</span>
                <span x-show="loading">Loading...</span>
            </button>
        </div>

        <div class="erp-notification-body">
            <template x-if="loading && items.length === 0">
                <p class="px-4 py-8 text-center text-sm text-muted">Loading notifications...</p>
            </template>
            <template x-if="!loading && items.length === 0">
                <div class="px-4 py-8 text-center">
                    <svg class="mx-auto h-8 w-8 text-muted" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                    <p class="mt-2 text-sm text-muted">You're all caught up</p>
                </div>
            </template>
            <template x-for="item in items" :key="item.id">
                <a :href="item.href" class="erp-notification-item" @@click="open = false">
                    <span class="erp-notification-icon" :class="'erp-notification-icon-' + item.type">
                        <template x-if="item.type === 'leave'">
                            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                        </template>
                        <template x-if="item.type === 'advance'">
                            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path d="M19 7V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-2"/><path d="M3 7h18v4H3z"/></svg>
                        </template>
                        <template x-if="item.type === 'attendance'">
                            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                        </template>
                        <template x-if="item.type === 'payroll' || item.type === 'bonus'">
                            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg>
                        </template>
                    </span>
                    <span class="min-w-0 flex-1">
                        <span class="block truncate text-sm font-medium text-foreground" x-text="item.title"></span>
                        <span class="block truncate text-xs text-muted" x-text="item.message"></span>
                    </span>
                </a>
            </template>
        </div>

        <div class="erp-notification-footer" x-show="items.length > 0">
            <a href="@Url.Action("Index", "Home")" class="text-xs font-medium text-primary hover:underline" @@click="open = false">View dashboard</a>
        </div>
    </div>
</div>
