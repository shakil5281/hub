@model IEnumerable<DailySalarySheetVm>
@{
    ViewData["Title"] = "Daily Salary Sheet";
    var date = (DateTime)ViewBag.Date;
}

@await Html.PartialAsync("~/Views/Shared/Partials/_PageHeader.cshtml", new ERP.Web.Models.PageHeaderVm
{
    Title = "Daily Salary Sheet",
    Subtitle = "Per-employee daily salary breakdown"
})

<div class="mb-4 rounded-xl border border-slate-200 bg-white p-4 shadow-sm flex flex-wrap gap-3 items-end justify-between">
    <form method="get" class="flex gap-3 items-end">
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Date</label>
            <input type="date" name="date" value="@date.ToString("yyyy-MM-dd")" class="rounded-lg border border-slate-300 px-3 py-2 text-sm" />
        </div>
        <button type="submit" class="rounded-lg bg-slate-700 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800">View</button>
    </form>
    <a href="@Url.Action("ExportDailySalarySheet", new { date = date.ToString("yyyy-MM-dd") })" class="rounded-lg bg-green-600 px-4 py-2 text-sm font-medium text-white hover:bg-green-700">Export Excel</a>
</div>

<div class="mb-4 grid grid-cols-2 gap-4 sm:grid-cols-4">
    <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <div class="text-xs text-slate-500">Total Employees</div>
        <div class="mt-1 text-xl font-bold text-slate-900">@Model.Count()</div>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <div class="text-xs text-slate-500">Present</div>
        <div class="mt-1 text-xl font-bold text-green-600">@Model.Count(m => m.IsPresent)</div>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <div class="text-xs text-slate-500">Absent</div>
        <div class="mt-1 text-xl font-bold text-red-600">@Model.Count(m => m.IsAbsent)</div>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <div class="text-xs text-slate-500">Total Payable</div>
        <div class="mt-1 text-xl font-bold text-slate-900">@Model.Sum(m => m.PayableAmount).ToString("N2")</div>
    </div>
</div>

@await Html.PartialAsync("~/Views/Shared/Partials/_ErpTableShellStart.cshtml", Model.Count())
<table id="dailySalaryTable" data-datatable class="erp-table display w-full">
    <thead>
        <tr>
            <th>Code</th><th>Name</th><th>Department</th>
            <th>Gross Salary</th><th>Working Days</th><th>Daily Rate</th>
            <th>Status</th><th>Payable</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.EmployeeCode</td>
                <td>@item.EmployeeName</td>
                <td>@item.Department</td>
                <td>@item.GrossSalary.ToString("N2")</td>
                <td>@item.WorkingDays</td>
                <td>@item.DailyRate.ToString("N2")</td>
                <td>
                    @if (item.IsHoliday)
                    {
                        <span class="rounded-full bg-purple-100 px-2 py-0.5 text-xs text-purple-800">Holiday</span>
                    }
                    else if (item.IsPresent)
                    {
                        <span class="rounded-full bg-green-100 px-2 py-0.5 text-xs text-green-800">Present</span>
                    }
                    else
                    {
                        <span class="rounded-full bg-red-100 px-2 py-0.5 text-xs text-red-800">Absent</span>
                    }
                </td>
                <td class="font-medium">@item.PayableAmount.ToString("N2")</td>
            </tr>
        }
    </tbody>
    <tfoot>
        <tr class="font-semibold bg-slate-50">
            <td colspan="7" class="px-4 py-2 text-right">Total Payable:</td>
            <td class="px-4 py-2">@Model.Sum(m => m.PayableAmount).ToString("N2")</td>
        </tr>
    </tfoot>
</table>
@await Html.PartialAsync("~/Views/Shared/Partials/_ErpTableShellEnd.cshtml")
