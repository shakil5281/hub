@model PayrollDetailVm
@{
    ViewData["Title"] = "Payslip";
}

<div class="mb-6 flex flex-wrap items-center justify-between gap-4">
    <div>
        <h1 class="text-2xl font-bold text-slate-900">Payslip</h1>
        <p class="text-sm text-slate-500">@Model.EmployeeName (@Model.EmployeeCode)</p>
    </div>
    <a asp-action="PayslipPdf" asp-route-detailId="@Model.Id"
       class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">Download PDF</a>
</div>

<div class="max-w-2xl rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
    <dl class="grid gap-4 sm:grid-cols-2">
        <div><dt class="text-sm text-slate-500">Gross Salary</dt><dd class="font-medium">@Model.GrossSalary.ToString("N2")</dd></div>
        <div><dt class="text-sm text-slate-500">Basic Salary</dt><dd class="font-medium">@Model.BasicSalary.ToString("N2")</dd></div>
        <div><dt class="text-sm text-slate-500">House Rent</dt><dd class="font-medium">@Model.HouseRent.ToString("N2")</dd></div>
        <div><dt class="text-sm text-slate-500">Medical Allowance</dt><dd class="font-medium">@Model.MedicalAllowance.ToString("N2")</dd></div>
        <div><dt class="text-sm text-slate-500">Food Allowance</dt><dd class="font-medium">@Model.FoodAllowance.ToString("N2")</dd></div>
        <div><dt class="text-sm text-slate-500">Conveyance</dt><dd class="font-medium">@Model.ConveyanceAllowance.ToString("N2")</dd></div>
        <div><dt class="text-sm text-slate-500">Payable Days</dt><dd class="font-medium">@Model.AttendancePayableDays</dd></div>
        <div><dt class="text-sm text-slate-500">Absent Deduction</dt><dd class="font-medium text-red-600">-@Model.AbsentDeduction.ToString("N2")</dd></div>
        <div><dt class="text-sm text-slate-500">Overtime</dt><dd class="font-medium">@Model.OvertimeAmount.ToString("N2")</dd></div>
        <div><dt class="text-sm text-slate-500">Night Bill</dt><dd class="font-medium">@Model.NightBillAmount.ToString("N2")</dd></div>
        <div><dt class="text-sm text-slate-500">Holiday Bill</dt><dd class="font-medium">@Model.HolidayBillAmount.ToString("N2")</dd></div>
        <div><dt class="text-sm text-slate-500">Advance Deduction</dt><dd class="font-medium text-red-600">-@Model.AdvanceDeduction.ToString("N2")</dd></div>
        <div class="sm:col-span-2 border-t border-slate-200 pt-4">
            <dt class="text-sm text-slate-500">Net Payable</dt>
            <dd class="text-xl font-bold text-slate-900">@Model.NetPayableSalary.ToString("N2")</dd>
        </div>
    </dl>
</div>
