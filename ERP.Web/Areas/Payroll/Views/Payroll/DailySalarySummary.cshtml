@model IEnumerable<DailySalarySummaryVm>
@{
    ViewData["Title"] = "Daily Salary Summary";
    var from = (DateTime)ViewBag.From;
    var to = (DateTime)ViewBag.To;
}

@await Html.PartialAsync("~/Views/Shared/Partials/_PageHeader.cshtml", new ERP.Web.Models.PageHeaderVm
{
    Title = "Daily Salary Summary",
    Subtitle = "Day-by-day payroll aggregation",
    Actions = [("Export Excel", Url.Action("ExportDailySalarySummary") + $"?from={from:yyyy-MM-dd}&to={to:yyyy-MM-dd}", "secondary")]
})

<div class="mb-4 rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
    <form method="get" class="flex flex-wrap gap-3 items-end">
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">From</label>
            <input type="date" name="from" value="@from.ToString("yyyy-MM-dd")" class="rounded-lg border border-slate-300 px-3 py-2 text-sm" />
        </div>
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">To</label>
            <input type="date" name="to" value="@to.ToString("yyyy-MM-dd")" class="rounded-lg border border-slate-300 px-3 py-2 text-sm" />
        </div>
        <button type="submit" class="rounded-lg bg-slate-700 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800">View</button>
    </form>
</div>

@await Html.PartialAsync("~/Views/Shared/Partials/_ErpTableShellStart.cshtml", Model.Count())
<table id="dailySummaryTable" data-datatable class="erp-table display w-full">
    <thead>
        <tr>
            <th>Date</th><th>Present</th><th>Absent</th><th>Holiday</th>
            <th>Total Payable</th><th>Absent Deduction</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Date.ToString("dd MMM yyyy")</td>
                <td><span class="text-green-600 font-medium">@item.PresentCount</span></td>
                <td><span class="text-red-600 font-medium">@item.AbsentCount</span></td>
                <td><span class="text-purple-600 font-medium">@item.HolidayCount</span></td>
                <td>@item.TotalPayable.ToString("N2")</td>
                <td class="text-red-600">@item.TotalAbsentDeduction.ToString("N2")</td>
            </tr>
        }
    </tbody>
    <tfoot>
        <tr class="font-semibold bg-slate-50">
            <td class="px-4 py-2">Total</td>
            <td class="px-4 py-2 text-green-600">@Model.Sum(m => m.PresentCount)</td>
            <td class="px-4 py-2 text-red-600">@Model.Sum(m => m.AbsentCount)</td>
            <td class="px-4 py-2">@Model.Sum(m => m.HolidayCount)</td>
            <td class="px-4 py-2">@Model.Sum(m => m.TotalPayable).ToString("N2")</td>
            <td class="px-4 py-2 text-red-600">@Model.Sum(m => m.TotalAbsentDeduction).ToString("N2")</td>
        </tr>
    </tfoot>
</table>
@await Html.PartialAsync("~/Views/Shared/Partials/_ErpTableShellEnd.cshtml")
