@model IEnumerable<StaffingPlanVm>
@using ERP.Web.Core.Interfaces.Services
@{
    ViewData["Title"] = "Staffing Plan";
    var year = (int)ViewBag.Year;
    var month = (int)ViewBag.Month;
}

@await Html.PartialAsync("~/Views/Shared/Partials/_PageHeader.cshtml", new ERP.Web.Models.PageHeaderVm
{
    Title = "Staffing Plan",
    Subtitle = "Define required headcount per organizational unit",
    Actions =
    [
        ("Hiring Requests", Url.Action("HiringRequests")!, "secondary"),
        ("Vacancy Report", Url.Action("VacancyReport", new { year, month })!, "secondary")
    ]
})

<div class="mb-4 rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
    <form method="get" class="flex flex-wrap gap-3 items-end">
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Year</label>
            <input type="number" name="year" value="@year" class="w-24 rounded-lg border border-slate-300 px-3 py-2 text-sm" />
        </div>
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Month</label>
            <select name="month" class="rounded-lg border border-slate-300 px-3 py-2 text-sm">
                @for (var m = 1; m <= 12; m++)
                {
                    <option value="@m" selected="@(month == m)">@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m)</option>
                }
            </select>
        </div>
        <button type="submit" class="rounded-lg bg-slate-700 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800">View</button>
    </form>
</div>

<div class="mb-4 rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
    <h2 class="mb-3 text-sm font-semibold text-slate-900">Add Staffing Plan</h2>
    <form asp-action="SaveStaffingPlan" method="post" class="flex flex-wrap items-end gap-3">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="0" />
        <input type="hidden" name="Year" value="@year" />
        <input type="hidden" name="Month" value="@month" />
        @await Html.PartialAsync("_OrgUnitFields")
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Required Count</label>
            <input type="number" name="RequiredCount" min="0" required class="w-24 rounded-lg border border-slate-300 px-3 py-2 text-sm" />
        </div>
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Remarks</label>
            <input name="Remarks" class="rounded-lg border border-slate-300 px-3 py-2 text-sm w-48" />
        </div>
        <button type="submit" class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">Add</button>
    </form>
</div>

@await Html.PartialAsync("~/Views/Shared/Partials/_ErpTableShellStart.cshtml", Model.Count())
<table id="staffingPlanTable" data-datatable class="erp-table display w-full">
    <thead>
        <tr>
            <th>Department</th><th>Section</th><th>Line</th><th>Designation</th>
            <th>Required</th><th>Remarks</th><th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Department</td>
                <td>@(string.IsNullOrEmpty(item.Section) || item.Section == "-" ? "—" : item.Section)</td>
                <td>@(string.IsNullOrEmpty(item.Line) || item.Line == "-" ? "—" : item.Line)</td>
                <td>@(string.IsNullOrEmpty(item.Designation) || item.Designation == "-" ? "—" : item.Designation)</td>
                <td class="font-medium">@item.RequiredCount</td>
                <td>@item.Remarks</td>
                <td>
                    <form asp-action="DeleteStaffingPlan" method="post" class="inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@item.Id" />
                        <input type="hidden" name="year" value="@year" />
                        <input type="hidden" name="month" value="@month" />
                        <button type="submit" class="text-red-600 hover:underline text-sm" onclick="return confirm('Delete this staffing plan?')">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
@await Html.PartialAsync("~/Views/Shared/Partials/_ErpTableShellEnd.cshtml")
