@model IEnumerable<HiringRequestVm>
@using ERP.Web.Core.Enums
@using ERP.Web.Core.Interfaces.Services
@{
    ViewData["Title"] = "Hiring Requests";
    var status = ViewBag.Status as HiringRequestStatus?;
}

@await Html.PartialAsync("~/Views/Shared/Partials/_PageHeader.cshtml", new ERP.Web.Models.PageHeaderVm
{
    Title = "Hiring Requests",
    Subtitle = "Manage hiring requests and approval workflow",
    Actions =
    [
        ("Staffing Plan", Url.Action("StaffingPlan")!, "secondary"),
        ("Export Excel", Url.Action("ExportHiringRequests", new { status })!, "secondary")
    ]
})

<div class="mb-4 rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
    <form method="get" class="flex flex-wrap gap-3 items-end">
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Status</label>
            <select name="status" class="rounded-lg border border-slate-300 px-3 py-2 text-sm">
                <option value="">All</option>
                @foreach (HiringRequestStatus s in Enum.GetValues<HiringRequestStatus>())
                {
                    <option value="@((int)s)" selected="@(status == s)">@s</option>
                }
            </select>
        </div>
        <button type="submit" class="rounded-lg bg-slate-700 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800">Filter</button>
    </form>
</div>

<div class="mb-4 rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
    <h2 class="mb-3 text-sm font-semibold text-slate-900">New Hiring Request</h2>
    <form asp-action="SaveHiringRequest" method="post" class="flex flex-col gap-3">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="0" />
        <input type="hidden" name="HiringRequestStatus" value="@((int)HiringRequestStatus.Draft)" />
        @await Html.PartialAsync("_OrgUnitFields")
        <div class="flex flex-wrap items-end gap-3">
            <div>
                <label class="mb-1 block text-xs font-medium text-slate-600">Requested Count</label>
                <input type="number" name="RequestedCount" min="1" required value="1" class="w-24 rounded-lg border border-slate-300 px-3 py-2 text-sm" />
            </div>
            <div>
                <label class="mb-1 block text-xs font-medium text-slate-600">Request Date</label>
                <input type="date" name="RequestDate" required value="@DateTime.Today.ToString("yyyy-MM-dd")" class="rounded-lg border border-slate-300 px-3 py-2 text-sm" />
            </div>
            <div>
                <label class="mb-1 block text-xs font-medium text-slate-600">Target Join Date</label>
                <input type="date" name="TargetJoinDate" class="rounded-lg border border-slate-300 px-3 py-2 text-sm" />
            </div>
            <div class="flex-1 min-w-[12rem]">
                <label class="mb-1 block text-xs font-medium text-slate-600">Reason</label>
                <input name="Reason" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" />
            </div>
        </div>
        <div class="flex gap-2">
            <button type="submit" name="submit" value="false" class="rounded-lg bg-slate-600 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700">Save Draft</button>
            <button type="submit" name="submit" value="true" class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">Submit for Approval</button>
        </div>
    </form>
</div>

@await Html.PartialAsync("~/Views/Shared/Partials/_ErpTableShellStart.cshtml", Model.Count())
<table id="hiringRequestsTable" data-datatable class="erp-table display w-full">
    <thead>
        <tr>
            <th>Department</th><th>Section</th><th>Line</th><th>Designation</th>
            <th>Count</th><th>Request Date</th><th>Target Join</th><th>Status</th><th>Reason</th><th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var badge = item.HiringRequestStatus switch
            {
                HiringRequestStatus.Approved => "bg-emerald-100 text-emerald-800",
                HiringRequestStatus.Pending => "bg-amber-100 text-amber-800",
                HiringRequestStatus.Rejected => "bg-red-100 text-red-800",
                HiringRequestStatus.Filled => "bg-blue-100 text-blue-800",
                _ => "bg-slate-100 text-slate-700"
            };
            <tr>
                <td>@item.Department</td>
                <td>@(item.Section == "-" ? "—" : item.Section)</td>
                <td>@(item.Line == "-" ? "—" : item.Line)</td>
                <td>@(item.Designation == "-" ? "—" : item.Designation)</td>
                <td class="font-medium">@item.RequestedCount</td>
                <td>@item.RequestDate.ToString("dd MMM yyyy")</td>
                <td>@(item.TargetJoinDate?.ToString("dd MMM yyyy") ?? "—")</td>
                <td><span class="rounded-full @badge px-2 py-0.5 text-xs">@item.StatusLabel</span></td>
                <td>@item.Reason</td>
                <td>
                    @if (item.HiringRequestStatus == HiringRequestStatus.Pending)
                    {
                        <form asp-action="ApproveHiringRequest" method="post" class="inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <input type="hidden" name="approved" value="true" />
                            <button type="submit" class="text-emerald-600 hover:underline text-sm mr-2">Approve</button>
                        </form>
                        <form asp-action="ApproveHiringRequest" method="post" class="inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <input type="hidden" name="approved" value="false" />
                            <button type="submit" class="text-red-600 hover:underline text-sm" onclick="return confirm('Reject this request?')">Reject</button>
                        </form>
                    }
                    else
                    {
                        <span class="text-slate-400 text-sm">—</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
@await Html.PartialAsync("~/Views/Shared/Partials/_ErpTableShellEnd.cshtml")
