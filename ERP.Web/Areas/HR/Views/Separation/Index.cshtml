@model IEnumerable<SeparationVm>
@using ERP.Web.Areas.Company.ViewModels
@using ERP.Web.Core.Enums
@using ERP.Web.Core.Interfaces.Services
@{
    ViewData["Title"] = "Employee Separation";
    var filter = ViewBag.Filter as SeparationFilterVm ?? new SeparationFilterVm();
    var departments = ViewBag.Departments as IReadOnlyList<DepartmentVm> ?? Array.Empty<DepartmentVm>();
}

@await Html.PartialAsync("~/Views/Shared/Partials/_PageHeader.cshtml", new ERP.Web.Models.PageHeaderVm
{
    Title = "Employee Separation",
    Subtitle = "View separation records and offboarding history",
    Actions =
    [
        ("New Separation", Url.Action("Create")!, "primary"),
        ("Export Excel", Url.Action("Export", new { from = filter.From?.ToString("yyyy-MM-dd"), to = filter.To?.ToString("yyyy-MM-dd"), separationType = filter.SeparationType.HasValue ? (int?)filter.SeparationType : null, departmentId = filter.DepartmentId })!, "secondary")
    ]
})

<div class="mb-4 rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
    <form method="get" class="flex flex-wrap gap-3 items-end">
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">From</label>
            <input type="date" name="from" value="@filter.From?.ToString("yyyy-MM-dd")" class="rounded-lg border border-slate-300 px-3 py-2 text-sm" />
        </div>
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">To</label>
            <input type="date" name="to" value="@filter.To?.ToString("yyyy-MM-dd")" class="rounded-lg border border-slate-300 px-3 py-2 text-sm" />
        </div>
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Type</label>
            <select name="separationType" class="rounded-lg border border-slate-300 px-3 py-2 text-sm">
                <option value="">All</option>
                @foreach (SeparationType t in Enum.GetValues<SeparationType>())
                {
                    <option value="@((int)t)" selected="@(filter.SeparationType == t)">@t</option>
                }
            </select>
        </div>
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Department</label>
            <select name="departmentId" class="rounded-lg border border-slate-300 px-3 py-2 text-sm min-w-[10rem]">
                <option value="">All</option>
                @foreach (var d in departments)
                {
                    <option value="@d.Id" selected="@(filter.DepartmentId == d.Id)">@d.Name</option>
                }
            </select>
        </div>
        <button type="submit" class="rounded-lg bg-slate-700 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800">Filter</button>
    </form>
</div>

@await Html.PartialAsync("~/Views/Shared/Partials/_ErpTableShellStart.cshtml", Model.Count())
<table id="separationsTable" data-datatable class="erp-table display w-full">
    <thead>
        <tr>
            <th>Code</th><th>Name</th><th>Department</th><th>Type</th>
            <th>Separation Date</th><th>Notice Date</th><th>Reason</th><th>Recorded</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td class="font-medium">@item.EmployeeCode</td>
                <td>@item.EmployeeName</td>
                <td>@item.Department</td>
                <td>@item.SeparationTypeLabel</td>
                <td>@item.SeparationDate.ToString("dd MMM yyyy")</td>
                <td>@(item.NoticeDate?.ToString("dd MMM yyyy") ?? "—")</td>
                <td>@item.Reason</td>
                <td>@item.CreatedAt.ToString("dd MMM yyyy")</td>
            </tr>
        }
    </tbody>
</table>
@await Html.PartialAsync("~/Views/Shared/Partials/_ErpTableShellEnd.cshtml")
