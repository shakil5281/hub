@model SeparationCreateVm
@using ERP.Web.Areas.HR.ViewModels
@using ERP.Web.Core.Enums
@using ERP.Web.Core.Interfaces.Services
@{
    ViewData["Title"] = "Initiate Separation";
    var employees = ViewBag.Employees as IEnumerable<EmployeeListItemVm> ?? Enumerable.Empty<EmployeeListItemVm>();
}

@await Html.PartialAsync("~/Views/Shared/Partials/_PageHeader.cshtml", new ERP.Web.Models.PageHeaderVm
{
    Title = "Initiate Separation",
    Subtitle = "Record employee separation and deactivate the employee",
    Actions = [("Back to list", Url.Action("Index")!, "secondary")]
})

<div class="max-w-2xl rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
    <form asp-action="Create" method="post" class="space-y-4">
        @Html.AntiForgeryToken()
        <div>
            <label class="mb-1 block text-sm font-medium text-slate-700">Employee</label>
            <select asp-for="EmployeeId" required class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm">
                <option value="">Select employee</option>
                @foreach (var e in employees)
                {
                    <option value="@e.Id" selected="@(Model.EmployeeId == e.Id)">@e.EmployeeCode — @e.FullName (@e.DepartmentName)</option>
                }
            </select>
        </div>
        <div>
            <label class="mb-1 block text-sm font-medium text-slate-700">Separation Type</label>
            <select asp-for="SeparationType" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm">
                @foreach (SeparationType t in Enum.GetValues<SeparationType>())
                {
                    <option value="@((int)t)">@t</option>
                }
            </select>
        </div>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div>
                <label class="mb-1 block text-sm font-medium text-slate-700">Separation Date</label>
                <input asp-for="SeparationDate" type="date" required class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" />
            </div>
            <div>
                <label class="mb-1 block text-sm font-medium text-slate-700">Notice Date</label>
                <input asp-for="NoticeDate" type="date" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" />
            </div>
        </div>
        <div>
            <label class="mb-1 block text-sm font-medium text-slate-700">Reason</label>
            <textarea asp-for="Reason" rows="2" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm"></textarea>
        </div>
        <div>
            <label class="mb-1 block text-sm font-medium text-slate-700">Remarks</label>
            <textarea asp-for="Remarks" rows="2" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm"></textarea>
        </div>
        <div class="flex gap-3 pt-2">
            <button type="submit" class="rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700" onclick="return confirm('This will deactivate the employee. Continue?')">Record Separation</button>
            <a asp-action="Index" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">Cancel</a>
        </div>
    </form>
</div>
