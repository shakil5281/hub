@model SectionVm
@{
    ViewData["Title"] = "Add Section";
}

@await Html.PartialAsync("~/Views/Shared/Partials/_PageHeader.cshtml", new ERP.Web.Models.PageHeaderVm
{
    Title = "Add Section",
    Subtitle = "Create a new section under a department",
    Actions = [("Back to Organogram", Url.Action("Index", new { tab = "sections" })!, "secondary")]
})

<div class="max-w-2xl">
    <form asp-action="CreateSection" method="post" class="erp-form-section">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="mb-4 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"></div>
        @await Html.PartialAsync("_SectionFormFields")
        <div class="erp-form-actions mt-6">
            <button type="submit" class="erp-btn-primary">Save Section</button>
            <a asp-action="Index" asp-route-tab="sections" class="erp-btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
