@model ShiftEditVm
@{
    ViewData["Title"] = Model.Id == 0 ? "Create Shift" : "Edit Shift";
}

<div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-900">@ViewData["Title"]</h1>
</div>

<div class="max-w-xl rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="grid gap-4 md:grid-cols-2">
            <div class="md:col-span-2">
                <label asp-for="Name" class="mb-1 block text-sm font-medium text-slate-700"></label>
                <input asp-for="Name" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" />
            </div>
            <div>
                <label asp-for="StartTime" class="mb-1 block text-sm font-medium text-slate-700"></label>
                <input asp-for="StartTime" type="time" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" />
            </div>
            <div>
                <label asp-for="EndTime" class="mb-1 block text-sm font-medium text-slate-700"></label>
                <input asp-for="EndTime" type="time" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" />
            </div>
            <div>
                <label asp-for="GraceMinutes" class="mb-1 block text-sm font-medium text-slate-700"></label>
                <input asp-for="GraceMinutes" type="number" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" />
            </div>
            <div>
                <label asp-for="PunchWindowBeforeMinutes" class="mb-1 block text-sm font-medium text-slate-700"></label>
                <input asp-for="PunchWindowBeforeMinutes" type="number" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" />
            </div>
            <div>
                <label asp-for="MaxOvertimeMinutes" class="mb-1 block text-sm font-medium text-slate-700"></label>
                <input asp-for="MaxOvertimeMinutes" type="number" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" />
            </div>
        </div>

        <div class="mt-6 flex gap-3">
            <button type="submit" class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">Save</button>
            <a asp-action="Index" class="rounded-lg border border-slate-300 px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">Cancel</a>
        </div>
    </form>
</div>
