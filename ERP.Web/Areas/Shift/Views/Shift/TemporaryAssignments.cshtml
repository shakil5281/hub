@model IEnumerable<TemporaryShiftVm>
@{
    ViewData["Title"] = "Temporary Shift Assignments";
    var employees = ViewBag.Employees as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var shifts = ViewBag.Shifts as IEnumerable<ShiftListItemVm> ?? Enumerable.Empty<ShiftListItemVm>();
    var from = (DateTime)ViewBag.From;
    var to = (DateTime)ViewBag.To;
}

@await Html.PartialAsync("~/Views/Shared/Partials/_PageHeader.cshtml", new ERP.Web.Models.PageHeaderVm
{
    Title = "Temporary Shift Assignments",
    Subtitle = "Assign employees to a different shift for specific dates"
})

<div class="mb-4 rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
    <form method="get" class="flex flex-wrap gap-3 items-end">
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">From</label>
            <input type="date" name="from" value="@from.ToString("yyyy-MM-dd")" class="rounded-lg border border-slate-300 px-3 py-2 text-sm" />
        </div>
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">To</label>
            <input type="date" name="to" value="@to.ToString("yyyy-MM-dd")" class="rounded-lg border border-slate-300 px-3 py-2 text-sm" />
        </div>
        <button type="submit" class="rounded-lg bg-slate-700 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800">Filter</button>
    </form>
</div>

<div class="mb-4 rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
    <h2 class="mb-3 text-sm font-semibold text-slate-900">Add Temporary Assignment</h2>
    <form asp-action="SaveTemporaryAssignment" method="post" class="flex flex-wrap items-end gap-3">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="0" />
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Employee</label>
            <select name="EmployeeId" required class="rounded-lg border border-slate-300 px-3 py-2 text-sm">
                <option value="">Select Employee</option>
                @foreach (var emp in employees)
                {
                    <option value="@emp.Id">@emp.FullName (@emp.EmployeeCode)</option>
                }
            </select>
        </div>
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Shift</label>
            <select name="ShiftId" required class="rounded-lg border border-slate-300 px-3 py-2 text-sm">
                <option value="">Select Shift</option>
                @foreach (var shift in shifts)
                {
                    <option value="@shift.Id">@shift.Name</option>
                }
            </select>
        </div>
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Date</label>
            <input type="date" name="AssignmentDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" required class="rounded-lg border border-slate-300 px-3 py-2 text-sm" />
        </div>
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Reason</label>
            <input name="Reason" class="rounded-lg border border-slate-300 px-3 py-2 text-sm w-48" />
        </div>
        <button type="submit" class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">Add</button>
    </form>
</div>

@await Html.PartialAsync("~/Views/Shared/Partials/_ErpTableShellStart.cshtml", Model.Count())
<table id="tempShiftTable" data-datatable class="erp-table display w-full">
    <thead>
        <tr>
            <th>Employee</th><th>Code</th><th>Department</th>
            <th>Shift</th><th>Date</th><th>Reason</th><th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.EmployeeName</td>
                <td>@item.EmployeeCode</td>
                <td>@item.Department</td>
                <td><span class="rounded-full bg-blue-100 px-2 py-0.5 text-xs text-blue-800">@item.ShiftName</span></td>
                <td>@item.AssignmentDate.ToString("dd MMM yyyy")</td>
                <td>@item.Reason</td>
                <td>
                    <form asp-action="DeleteTemporaryAssignment" method="post" class="inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@item.Id" />
                        <button type="submit" class="text-red-600 hover:underline text-sm" onclick="return confirm('Delete this assignment?')">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
@await Html.PartialAsync("~/Views/Shared/Partials/_ErpTableShellEnd.cshtml")
