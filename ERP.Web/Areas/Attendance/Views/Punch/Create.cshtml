@model PunchRecordCreateVm
@{
    ViewData["Title"] = "Add Punch";
    var employees = (IReadOnlyList<EmployeeListItemVm>)ViewBag.Employees!;
}

<div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-900">Add Manual Punch</h1>
</div>

<div class="max-w-xl rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div class="space-y-4">
            <div>
                <label class="mb-1 block text-sm font-medium text-slate-700">Employee</label>
                <select asp-for="EmployeeId" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm">
                    <option value="">Select employee</option>
                    @foreach (var e in employees)
                    {
                        <option value="@e.Id">@e.FullName (@e.PunchNumber)</option>
                    }
                </select>
            </div>
            <div>
                <label asp-for="PunchTime" class="mb-1 block text-sm font-medium text-slate-700"></label>
                <input asp-for="PunchTime" type="datetime-local" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" />
            </div>
            <div>
                <label asp-for="PunchType" class="mb-1 block text-sm font-medium text-slate-700">Punch Type</label>
                <select asp-for="PunchType" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm"
                        asp-items="Html.GetEnumSelectList<ERP.Web.Core.Enums.PunchType>()"></select>
            </div>
        </div>

        <div class="mt-6 flex gap-3">
            <button type="submit" class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">Save</button>
            <a asp-action="Index" class="rounded-lg border border-slate-300 px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">Cancel</a>
        </div>
    </form>
</div>
