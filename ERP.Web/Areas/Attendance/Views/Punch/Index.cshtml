@model IEnumerable<PunchRecordVm>
@{
    ViewData["Title"] = "Punch Records";
    var from = (DateTime)ViewBag.From!;
    var to = (DateTime)ViewBag.To!;
}

@await Html.PartialAsync("~/Views/Shared/Partials/_PageHeader.cshtml", new ERP.Web.Models.PageHeaderVm
{
    Title = "Punch Records",
    Subtitle = "View and manage attendance punches",
    Actions =
    [
        ("Add Punch", Url.Action("Create")!, "primary"),
        ("Import", Url.Action("Import")!, "secondary")
    ]
})

<form method="get" class="mb-4 flex flex-wrap items-end gap-3 rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
    <div>
        <label class="mb-1 block text-xs font-medium text-slate-600">From</label>
        <input type="date" name="from" value="@from.ToString("yyyy-MM-dd")" class="erp-input" data-datepicker placeholder="From date" />
    </div>
    <div>
        <label class="erp-label-muted">To</label>
        <input type="date" name="to" value="@to.ToString("yyyy-MM-dd")" class="erp-input" data-datepicker placeholder="To date" />
    </div>
    <button type="submit" class="rounded-lg bg-slate-800 px-4 py-2 text-sm text-white hover:bg-slate-900">Filter</button>
</form>

@await Html.PartialAsync("~/Views/Shared/Partials/_ErpTableShellStart.cshtml", Model.Count())
    <table id="punchTable" data-datatable class="erp-table display w-full">
        <thead>
            <tr>
                <th>Employee</th>
                <th>Punch No</th>
                <th>Time</th>
                <th>Type</th>
                <th>Source</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.EmployeeName</td>
                    <td>@item.PunchNumber</td>
                    <td>@item.PunchTime.ToString("dd MMM yyyy HH:mm")</td>
                    <td>@item.PunchType</td>
                    <td>@item.Source</td>
                </tr>
            }
        </tbody>
    </table>
@await Html.PartialAsync("~/Views/Shared/Partials/_ErpTableShellEnd.cshtml")