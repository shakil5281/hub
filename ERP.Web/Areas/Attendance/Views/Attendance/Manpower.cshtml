@model IEnumerable<ManpowerVm>
@{
    ViewData["Title"] = "Manpower Report";
    var date = (DateTime)ViewBag.Date;
}

@await Html.PartialAsync("~/Views/Shared/Partials/_PageHeader.cshtml", new ERP.Web.Models.PageHeaderVm
{
    Title = "Manpower Report",
    Subtitle = "Daily workforce presence by department",
    Actions = [("Export Excel", Url.Action("ExportManpower", new { date = date.ToString("yyyy-MM-dd") })!, "secondary")]
})

<div class="mb-4 rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
    <form method="get" class="flex gap-3 items-end">
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Date</label>
            <input type="date" name="date" value="@date.ToString("yyyy-MM-dd")" class="rounded-lg border border-slate-300 px-3 py-2 text-sm" />
        </div>
        <button type="submit" class="rounded-lg bg-slate-700 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800">View</button>
    </form>
</div>

<div class="mb-4 grid grid-cols-2 gap-4 sm:grid-cols-4">
    <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <div class="text-xs text-slate-500">Total</div>
        <div class="mt-1 text-xl font-bold text-slate-900">@Model.Sum(m => m.Total)</div>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <div class="text-xs text-slate-500">Present</div>
        <div class="mt-1 text-xl font-bold text-green-600">@Model.Sum(m => m.Present)</div>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <div class="text-xs text-slate-500">Absent</div>
        <div class="mt-1 text-xl font-bold text-red-600">@Model.Sum(m => m.Absent)</div>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <div class="text-xs text-slate-500">On Leave</div>
        <div class="mt-1 text-xl font-bold text-orange-500">@Model.Sum(m => m.OnLeave)</div>
    </div>
</div>

@await Html.PartialAsync("~/Views/Shared/Partials/_ErpTableShellStart.cshtml", Model.Count())
<table id="manpowerTable" data-datatable class="erp-table display w-full">
    <thead>
        <tr>
            <th>Department</th><th>Section</th><th>Line</th>
            <th>Total</th><th>Present</th><th>Absent</th><th>On Leave</th><th>Holiday</th>
            <th>Attendance %</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var attendancePct = item.Total > 0 ? Math.Round((double)item.Present / item.Total * 100, 1) : 0.0;
            <tr>
                <td class="font-medium">@item.Department</td>
                <td>@item.Section</td>
                <td>@item.Line</td>
                <td>@item.Total</td>
                <td><span class="text-green-600 font-medium">@item.Present</span></td>
                <td><span class="text-red-600 font-medium">@item.Absent</span></td>
                <td><span class="text-orange-500 font-medium">@item.OnLeave</span></td>
                <td><span class="text-purple-600 font-medium">@item.Holiday</span></td>
                <td>
                    <div class="flex items-center gap-2">
                        <div class="h-2 flex-1 rounded-full bg-slate-200">
                            <div class="h-2 rounded-full bg-green-500" style="width:@attendancePct%"></div>
                        </div>
                        <span class="text-xs">@attendancePct%</span>
                    </div>
                </td>
            </tr>
        }
    </tbody>
    <tfoot>
        <tr class="font-semibold bg-slate-50">
            <td colspan="3" class="px-4 py-2">Total</td>
            <td class="px-4 py-2">@Model.Sum(m => m.Total)</td>
            <td class="px-4 py-2 text-green-600">@Model.Sum(m => m.Present)</td>
            <td class="px-4 py-2 text-red-600">@Model.Sum(m => m.Absent)</td>
            <td class="px-4 py-2 text-orange-500">@Model.Sum(m => m.OnLeave)</td>
            <td class="px-4 py-2 text-purple-600">@Model.Sum(m => m.Holiday)</td>
            <td></td>
        </tr>
    </tfoot>
</table>
@await Html.PartialAsync("~/Views/Shared/Partials/_ErpTableShellEnd.cshtml")
