@model IEnumerable<OtDeductionVm>
@{
    ViewData["Title"] = "OT Deduction";
    var periodId = ViewBag.PeriodId as int?;
    var periods = ViewBag.Periods as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}

@await Html.PartialAsync("~/Views/Shared/Partials/_PageHeader.cshtml", new ERP.Web.Models.PageHeaderVm
{
    Title = "OT Deduction Reconciliation",
    Subtitle = "Overtime vs. absent deduction per payroll period",
    Actions = [("Export Excel", Url.Action("ExportOtDeduction", new { periodId })!, "secondary")]
})

<div class="mb-4 rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
    <form method="get" class="flex gap-3 items-end">
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Payroll Period</label>
            <select name="periodId" class="rounded-lg border border-slate-300 px-3 py-2 text-sm">
                <option value="">Select Period</option>
                @foreach (var p in periods)
                {
                    <option value="@p.Id" selected="@(periodId == p.Id)">@p.Name</option>
                }
            </select>
        </div>
        <button type="submit" class="rounded-lg bg-slate-700 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800">View</button>
    </form>
</div>

@if (Model.Any())
{
    <div class="mb-4 grid grid-cols-3 gap-4">
        <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
            <div class="text-xs text-slate-500">Total OT Amount</div>
            <div class="mt-1 text-xl font-bold text-green-600">@Model.Sum(m => m.OvertimeAmount).ToString("N2")</div>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
            <div class="text-xs text-slate-500">Total Absent Deduction</div>
            <div class="mt-1 text-xl font-bold text-red-600">@Model.Sum(m => m.AbsentDeduction).ToString("N2")</div>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
            <div class="text-xs text-slate-500">Net Adjustment</div>
            <div class="mt-1 text-xl font-bold text-slate-900">@Model.Sum(m => m.NetAdjustment).ToString("N2")</div>
        </div>
    </div>

    @await Html.PartialAsync("~/Views/Shared/Partials/_ErpTableShellStart.cshtml", Model.Count())
    <table id="otDeductionTable" data-datatable class="erp-table display w-full">
        <thead>
            <tr>
                <th>Code</th><th>Name</th><th>Department</th>
                <th>OT Minutes</th><th>OT Amount</th><th>Absent Deduction</th><th>Net Adjustment</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.EmployeeCode</td>
                    <td>@item.EmployeeName</td>
                    <td>@item.Department</td>
                    <td>@item.OvertimeMinutes</td>
                    <td class="text-green-600">@item.OvertimeAmount.ToString("N2")</td>
                    <td class="text-red-600">@item.AbsentDeduction.ToString("N2")</td>
                    <td class="font-semibold @(item.NetAdjustment >= 0 ? "text-green-600" : "text-red-600")">
                        @item.NetAdjustment.ToString("N2")
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @await Html.PartialAsync("~/Views/Shared/Partials/_ErpTableShellEnd.cshtml")
}
else if (periodId.HasValue)
{
    <div class="rounded-xl border border-slate-200 bg-white p-8 text-center text-slate-500 shadow-sm">
        No data found for the selected period.
    </div>
}
else
{
    <div class="rounded-xl border border-slate-200 bg-white p-8 text-center text-slate-500 shadow-sm">
        Select a payroll period to view OT deduction reconciliation.
    </div>
}
