@model IEnumerable<AbsentStatusVm>
@{
    ViewData["Title"] = "Absent Status";
    var date = (DateTime)ViewBag.Date;
}

@await Html.PartialAsync("~/Views/Shared/Partials/_PageHeader.cshtml", new ERP.Web.Models.PageHeaderVm
{
    Title = "Absent Status",
    Subtitle = "Employees absent on a given date",
    Actions = [("Export Excel", Url.Action("ExportAbsentStatus", new { date = date.ToString("yyyy-MM-dd") })!, "secondary")]
})

<div class="mb-4 rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
    <form method="get" class="flex gap-3 items-end">
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Date</label>
            <input type="date" name="date" value="@date.ToString("yyyy-MM-dd")" class="rounded-lg border border-slate-300 px-3 py-2 text-sm" />
        </div>
        <button type="submit" class="rounded-lg bg-slate-700 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800">View</button>
    </form>
</div>

<div class="mb-4 grid grid-cols-3 gap-4">
    <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <div class="text-xs text-slate-500">Total Absent</div>
        <div class="mt-1 text-xl font-bold text-red-600">@Model.Count()</div>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <div class="text-xs text-slate-500">On Approved Leave</div>
        <div class="mt-1 text-xl font-bold text-blue-600">@Model.Count(m => m.IsOnLeave)</div>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <div class="text-xs text-slate-500">Unexpected Absent</div>
        <div class="mt-1 text-xl font-bold text-orange-600">@Model.Count(m => !m.IsOnLeave && !m.IsHoliday)</div>
    </div>
</div>

@await Html.PartialAsync("~/Views/Shared/Partials/_ErpTableShellStart.cshtml", Model.Count())
<table id="absentTable" data-datatable class="erp-table display w-full">
    <thead>
        <tr>
            <th>Code</th><th>Name</th><th>Department</th><th>Section</th>
            <th>Date</th><th>On Leave</th><th>Leave Type</th><th>Holiday</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.EmployeeCode</td>
                <td>@item.EmployeeName</td>
                <td>@item.Department</td>
                <td>@item.Section</td>
                <td>@item.Date.ToString("dd MMM yyyy")</td>
                <td>
                    @if (item.IsOnLeave)
                    {
                        <span class="rounded-full bg-blue-100 px-2 py-0.5 text-xs text-blue-800">Yes</span>
                    }
                    else
                    {
                        <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs text-slate-600">No</span>
                    }
                </td>
                <td>@(item.IsOnLeave ? item.LeaveType : "-")</td>
                <td>
                    @if (item.IsHoliday)
                    {
                        <span class="rounded-full bg-purple-100 px-2 py-0.5 text-xs text-purple-800">Yes</span>
                    }
                    else
                    {
                        <span>-</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
@await Html.PartialAsync("~/Views/Shared/Partials/_ErpTableShellEnd.cshtml")
