@model IEnumerable<DailyOvertimeSummaryVm>
@{
    ViewData["Title"] = "Daily Overtime Summary";
    var from = (DateTime)ViewBag.From;
    var to = (DateTime)ViewBag.To;
}

@await Html.PartialAsync("~/Views/Shared/Partials/_PageHeader.cshtml", new ERP.Web.Models.PageHeaderVm
{
    Title = "Daily Overtime Summary",
    Subtitle = "Aggregated overtime by employee over a date range"
})

<div class="mb-4 rounded-xl border border-slate-200 bg-white p-4 shadow-sm flex flex-wrap gap-3 items-end justify-between">
    <form method="get" class="flex gap-3 items-end">
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">From</label>
            <input type="date" name="from" value="@from.ToString("yyyy-MM-dd")" class="rounded-lg border border-slate-300 px-3 py-2 text-sm" />
        </div>
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">To</label>
            <input type="date" name="to" value="@to.ToString("yyyy-MM-dd")" class="rounded-lg border border-slate-300 px-3 py-2 text-sm" />
        </div>
        <button type="submit" class="rounded-lg bg-slate-700 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800">View</button>
    </form>
    <a href="@Url.Action("ExportDailyOvertime", new { from = from.ToString("yyyy-MM-dd"), to = to.ToString("yyyy-MM-dd") })" class="rounded-lg bg-green-600 px-4 py-2 text-sm font-medium text-white hover:bg-green-700">Export Excel</a>
</div>

<div class="mb-4 grid grid-cols-3 gap-4">
    <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <div class="text-xs text-slate-500">Employees with OT</div>
        <div class="mt-1 text-xl font-bold text-slate-900">@Model.Count()</div>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <div class="text-xs text-slate-500">Total OT Hours</div>
        <div class="mt-1 text-xl font-bold text-blue-600">@Model.Sum(m => m.TotalOtHours).ToString("N2")</div>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <div class="text-xs text-slate-500">Total OT Amount</div>
        <div class="mt-1 text-xl font-bold text-green-600">@Model.Sum(m => m.TotalOtAmount).ToString("N2")</div>
    </div>
</div>

@await Html.PartialAsync("~/Views/Shared/Partials/_ErpTableShellStart.cshtml", Model.Count())
<table id="otSummaryTable" data-datatable class="erp-table display w-full">
    <thead>
        <tr>
            <th>Code</th><th>Name</th><th>Department</th>
            <th>OT Days</th><th>Total OT Min</th><th>Total OT Hours</th><th>Total OT Amount</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.EmployeeCode</td>
                <td>@item.EmployeeName</td>
                <td>@item.Department</td>
                <td>@item.OtDays</td>
                <td>@item.TotalOtMinutes</td>
                <td class="text-blue-600 font-medium">@item.TotalOtHours.ToString("N2")</td>
                <td class="text-green-600 font-medium">@item.TotalOtAmount.ToString("N2")</td>
            </tr>
        }
    </tbody>
    <tfoot>
        <tr class="font-semibold bg-slate-50">
            <td colspan="3" class="px-4 py-2">Total</td>
            <td class="px-4 py-2">@Model.Sum(m => m.OtDays)</td>
            <td class="px-4 py-2">@Model.Sum(m => m.TotalOtMinutes)</td>
            <td class="px-4 py-2 text-blue-600">@Model.Sum(m => m.TotalOtHours).ToString("N2")</td>
            <td class="px-4 py-2 text-green-600">@Model.Sum(m => m.TotalOtAmount).ToString("N2")</td>
        </tr>
    </tfoot>
</table>
@await Html.PartialAsync("~/Views/Shared/Partials/_ErpTableShellEnd.cshtml")
