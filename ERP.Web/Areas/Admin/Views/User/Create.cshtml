@model UserCreateVm
@{
    ViewData["Title"] = "Create User";
    var roles = (IList<string>)ViewBag.Roles!;
}

<div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-900">Create User</h1>
</div>

<div class="max-w-xl rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="mb-4 text-sm text-red-600"></div>

        <div class="space-y-4">
            <div>
                <label asp-for="Email" class="mb-1 block text-sm font-medium text-slate-700"></label>
                <input asp-for="Email" type="email" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" />
                <span asp-validation-for="Email" class="text-sm text-red-600"></span>
            </div>
            <div>
                <label asp-for="FullName" class="mb-1 block text-sm font-medium text-slate-700"></label>
                <input asp-for="FullName" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" />
                <span asp-validation-for="FullName" class="text-sm text-red-600"></span>
            </div>
            <div>
                <label asp-for="Password" class="mb-1 block text-sm font-medium text-slate-700"></label>
                <input asp-for="Password" type="password" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" />
                <span asp-validation-for="Password" class="text-sm text-red-600"></span>
            </div>
            <div>
                <label asp-for="RoleName" class="mb-1 block text-sm font-medium text-slate-700"></label>
                <select asp-for="RoleName" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm">
                    @foreach (var role in roles)
                    {
                        <option value="@role">@role</option>
                    }
                </select>
            </div>
        </div>

        <div class="mt-6 flex gap-3">
            <button type="submit" class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">Save</button>
            <a asp-action="Index" class="rounded-lg border border-slate-300 px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
