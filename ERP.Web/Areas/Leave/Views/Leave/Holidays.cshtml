@model IEnumerable<HolidayVm>
@{
    ViewData["Title"] = "Holiday Calendar";
    var year = (int)ViewBag.Year;
}

@await Html.PartialAsync("~/Views/Shared/Partials/_PageHeader.cshtml", new ERP.Web.Models.PageHeaderVm
{
    Title = "Holiday Calendar",
    Subtitle = "Manage public and restricted holidays",
    Actions = [("Export Excel", Url.Action("ExportHolidays", new { year })!, "secondary")]
})

<div class="mb-4 rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
    <form method="get" class="flex gap-3 items-end">
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Year</label>
            <input type="number" name="year" value="@year" class="w-24 rounded-lg border border-slate-300 px-3 py-2 text-sm" />
        </div>
        <button type="submit" class="rounded-lg bg-slate-700 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800">View</button>
    </form>
</div>

<div class="mb-4 rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
    <h2 class="mb-3 text-sm font-semibold text-slate-900">Add Holiday</h2>
    <form asp-action="SaveHoliday" method="post" class="flex flex-wrap items-end gap-3">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="0" />
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Name</label>
            <input name="Name" required class="rounded-lg border border-slate-300 px-3 py-2 text-sm w-48" />
        </div>
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Date</label>
            <input type="date" name="HolidayDate" required class="rounded-lg border border-slate-300 px-3 py-2 text-sm" />
        </div>
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Type</label>
            <select name="HolidayType" class="rounded-lg border border-slate-300 px-3 py-2 text-sm">
                <option value="1">Public Holiday</option>
                <option value="2">Restricted Holiday</option>
                <option value="3">Weekly Off</option>
            </select>
        </div>
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Description</label>
            <input name="Description" class="rounded-lg border border-slate-300 px-3 py-2 text-sm w-40" />
        </div>
        <button type="submit" class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">Add</button>
    </form>
</div>

@await Html.PartialAsync("~/Views/Shared/Partials/_ErpTableShellStart.cshtml", Model.Count())
<table id="holidaysTable" data-datatable class="erp-table display w-full">
    <thead>
        <tr><th>Name</th><th>Date</th><th>Day</th><th>Type</th><th>Description</th><th>Actions</th></tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td class="font-medium">@item.Name</td>
                <td>@item.HolidayDate.ToString("dd MMM yyyy")</td>
                <td>@item.HolidayDate.DayOfWeek</td>
                <td>
                    @{
                        var badge = item.HolidayType == 1 ? "bg-red-100 text-red-800" :
                                     item.HolidayType == 2 ? "bg-yellow-100 text-yellow-800" : "bg-slate-100 text-slate-700";
                    }
                    <span class="rounded-full @badge px-2 py-0.5 text-xs">@item.HolidayTypeName</span>
                </td>
                <td>@item.Description</td>
                <td>
                    <form asp-action="DeleteHoliday" method="post" class="inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@item.Id" />
                        <input type="hidden" name="year" value="@year" />
                        <button type="submit" class="text-red-600 hover:underline text-sm" onclick="return confirm('Delete this holiday?')">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
@await Html.PartialAsync("~/Views/Shared/Partials/_ErpTableShellEnd.cshtml")
