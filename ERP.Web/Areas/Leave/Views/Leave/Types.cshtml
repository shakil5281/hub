@model IEnumerable<LeaveTypeVm>
@{
    ViewData["Title"] = "Leave Types";
}

@await Html.PartialAsync("~/Views/Shared/Partials/_PageHeader.cshtml", new ERP.Web.Models.PageHeaderVm
{
    Title = "Leave Types",
    Subtitle = "Configure leave categories and limits"
})

<div class="mb-4 rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
    <h2 class="mb-3 text-sm font-semibold text-slate-900">Add Leave Type</h2>
    <form asp-action="SaveType" method="post" class="flex flex-wrap items-end gap-3">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="0" />
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Name</label>
            <input name="Name" required class="rounded-lg border border-slate-300 px-3 py-2 text-sm" />
        </div>
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Max Days/Year</label>
            <input name="MaxDaysPerYear" type="number" required value="10" class="rounded-lg border border-slate-300 px-3 py-2 text-sm" />
        </div>
        <div class="flex items-center gap-2 pb-2">
            <input name="IsPaid" type="checkbox" value="true" checked class="rounded border-slate-300" />
            <label class="text-xs font-medium text-slate-600">Paid Leave</label>
        </div>
        <button type="submit" class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">Add</button>
    </form>
</div>

@await Html.PartialAsync("~/Views/Shared/Partials/_ErpTableShellStart.cshtml", Model.Count())
    <table id="leaveTypesTable" data-datatable class="erp-table display w-full">
        <thead>
            <tr><th>Name</th><th>Max Days</th><th>Paid</th><th>Actions</th></tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <form asp-action="SaveType" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Id" value="@item.Id" />
                        <td><input name="Name" value="@item.Name" class="w-full rounded border border-slate-300 px-2 py-1 text-sm" /></td>
                        <td><input name="MaxDaysPerYear" type="number" value="@item.MaxDaysPerYear" class="w-24 rounded border border-slate-300 px-2 py-1 text-sm" /></td>
                        <td><input name="IsPaid" type="checkbox" value="true" checked="@item.IsPaid" class="rounded border-slate-300" /></td>
                        <td><button type="submit" class="text-blue-600 hover:underline">Save</button></td>
                    </form>
                </tr>
            }
        </tbody>
    </table>
@await Html.PartialAsync("~/Views/Shared/Partials/_ErpTableShellEnd.cshtml")