@model IEnumerable<LeaveApplicationVm>
@{
    ViewData["Title"] = "Leave Applications";
    var employees = (IReadOnlyList<EmployeeListItemVm>)ViewBag.Employees!;
    var leaveTypes = (IReadOnlyList<LeaveTypeVm>)ViewBag.LeaveTypes!;
}

@await Html.PartialAsync("~/Views/Shared/Partials/_PageHeader.cshtml", new ERP.Web.Models.PageHeaderVm
{
    Title = "Leave Applications",
    Subtitle = "Submit and approve leave requests"
})

<div class="mb-4 rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
    <h2 class="mb-3 text-sm font-semibold text-slate-900">New Application</h2>
    <form asp-action="SubmitApplication" method="post" class="grid gap-3 md:grid-cols-5 md:items-end">
        @Html.AntiForgeryToken()
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Employee</label>
            <select name="EmployeeId" required class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm">
                @foreach (var e in employees)
                {
                    <option value="@e.Id">@e.FullName</option>
                }
            </select>
        </div>
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">Leave Type</label>
            <select name="LeaveTypeId" required class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm">
                @foreach (var t in leaveTypes)
                {
                    <option value="@t.Id">@t.Name</option>
                }
            </select>
        </div>
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">From</label>
            <input name="FromDate" type="date" required class="erp-input" data-datepicker placeholder="From date" />
        </div>
        <div>
            <label class="mb-1 block text-xs font-medium text-slate-600">To</label>
            <input name="ToDate" type="date" required class="erp-input" data-datepicker placeholder="To date" />
        </div>
        <div>
            <button type="submit" class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">Submit</button>
        </div>
    </form>
</div>

@await Html.PartialAsync("~/Views/Shared/Partials/_ErpTableShellStart.cshtml", Model.Count())
    <table id="applicationsTable" data-datatable class="erp-table display w-full">
        <thead>
            <tr>
                <th>Employee</th>
                <th>Type</th>
                <th>From</th>
                <th>To</th>
                <th>Days</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.EmployeeName</td>
                    <td>@item.LeaveTypeName</td>
                    <td>@item.FromDate.ToString("dd MMM yyyy")</td>
                    <td>@item.ToDate.ToString("dd MMM yyyy")</td>
                    <td>@item.TotalDays</td>
                    <td>@item.ApprovalStatus</td>
                    <td class="space-x-2 whitespace-nowrap">
                        @if (item.ApprovalStatus == "Pending")
                        {
                            <form asp-action="Approve" asp-route-id="@item.Id" asp-route-approved="true" method="post" class="inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="text-green-600 hover:underline">Approve</button>
                            </form>
                            <form asp-action="Approve" asp-route-id="@item.Id" asp-route-approved="false" method="post" class="inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="text-red-600 hover:underline">Reject</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
@await Html.PartialAsync("~/Views/Shared/Partials/_ErpTableShellEnd.cshtml")